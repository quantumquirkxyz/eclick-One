{
  "name": "eclick-one",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter '*' dev",
    "dev:web": "bun --cwd apps/web dev",
    "dev:api": "bun --cwd apps/api dev",
    "build": "bun --filter '*' build",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.2.19",
    "@types/node": "^24.0.0",
    "typescript": "^6.0.0"
  }
}

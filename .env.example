# Runtime
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3000
VITE_API_BASE_URL=/api/v1
CORS_ORIGINS=http://localhost:5173
REPOSITORY_MODE=mock

# Auth/session management
AUTH_JWT_SECRET=replace-with-a-strong-random-secret
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

# Turso (required only when REPOSITORY_MODE=turso)
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-token

# On-chain integration (optional; omit to run without Web3)
ONCHAIN_RPC_URL=http://localhost:8545
ONCHAIN_CHAIN_ID=31337
ONCHAIN_ORDER_MANAGER_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
ONCHAIN_PAYMENT_LEDGER_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
ONCHAIN_COLLECTOR_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
AGENT_PORT=3100
COMPLIANCE_AGENT_PORT=3101
AGENT_API_BASE_URL=http://localhost:3000
AGENT_POLL_INTERVAL=2000

# Optional AI integration; not used by the main application flow
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

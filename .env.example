# Runtime
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3000
VITE_API_BASE_URL=/api/v1
CORS_ORIGINS=http://localhost:5173

# Persistence mode: mock | sql
REPOSITORY_MODE=sql

# Azure SQL Database
# Never commit the real password. Copy this file to .env and set it locally or in
# the secret manager of the deployment platform.
AZURE_SQL_SERVER=ec
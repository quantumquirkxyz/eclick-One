# Runtime
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3000
VITE_API_BASE_URL=/api/v1
CORS_ORIGINS=http://localhost:5173
REPOSITORY_MODE=mock

# Azure SQL Database (required only when REPOSITORY_MODE=sql)
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_PORT=1433
AZURE_SQL_DATABASE=eclick_one
AZURE_SQL_USER=your-user
AZURE_SQL_PASSWORD=your-password
AZURE_SQL_ENCRYPT=true
AZURE_SQL_TRUST_SERVER_CERTIFICATE=false
AZURE_SQL_POOL_MAX=10
AZURE_SQL_POOL_MIN=0
AZURE_SQL_POOL_IDLE_TIMEOUT_MS=30000

# Optional AI integration; not used by the main application flow
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

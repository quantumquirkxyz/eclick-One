# Runtime
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3000
VITE_API_BASE_URL=/api/v1
CORS_ORIGINS=http://localhost:5173
REPOSITORY_MODE=mock
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-characters
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Turso (required only when REPOSITORY_MODE=turso)
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-token
TURSO_POOL_MIN=2
TURSO_POOL_MAX=10
TURSO_CONNECTION_TIMEOUT_MS=5000
TURSO_QUERY_TIMEOUT_MS=10000
TURSO_CIRCUIT_BREAKER_FAILURES=5
TURSO_CIRCUIT_BREAKER_RESET_MS=30000

# Azure SQL resilience defaults (used only by Azure SQL adapter)
AZURE_SQL_POOL_MIN=2
AZURE_SQL_POOL_MAX=10
AZURE_SQL_CONNECTION_TIMEOUT_MS=5000
AZURE_SQL_QUERY_TIMEOUT_MS=10000
AZURE_SQL_CIRCUIT_BREAKER_FAILURES=5
AZURE_SQL_CIRCUIT_BREAKER_RESET_MS=30000

# On-chain integration (optional; omit to run without Web3)
ONCHAIN_RPC_URL=http://localhost:8545
ONCHAIN_CHAIN_ID=31337
ONCHAIN_ORDER_MANAGER_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
ONCHAIN_PAYMENT_LEDGER_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
ONCHAIN_COLLECTOR_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
AGENT_PORT=3100
COMPLIANCE_AGENT_PORT=3101
AGENT_API_BASE_URL=http://localhost:3000
AGENT_POLL_INTERVAL=2000

# Optional AI integration; not used by the main application flow
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
